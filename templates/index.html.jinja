<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <title>Backstage</title>
</head>

<body class="bg-gradient-to-br from-[#F5EEDD] via-white to-[#F5EEDD] text-[#06202B] font-sans antialiased">

  <div class="min-h-screen flex flex-col">

    {% include "components/navbar.html.jinja"%}

    <!-- HERO -->
    <main class="flex-1 flex items-center relative overflow-hidden">
      
      <!-- Background Glow -->
      <div class="absolute w-[500px] h-[500px] bg-[#7AE2CF]/30 blur-[120px] rounded-full top-[-100px] left-[-100px]"></div>
      <div class="absolute w-[400px] h-[400px] bg-[#077A7D]/20 blur-[120px] rounded-full bottom-[-100px] right-[-100px]"></div>

      <div class="max-w-7xl mx-auto px-6 py-24 grid md:grid-cols-2 gap-12 items-center relative z-10">

        <!-- TEXT -->
        <div>
          <h2 class="text-5xl font-semibold mb-6 leading-tight">
            Meet new musicians
          </h2>

          <p class="text-lg text-[#06202B]/80 max-w-xl leading-relaxed mb-8">
            Join a growing community to connect with artists through your interests 
            and cultivate a like-minded creative network.
          </p>

          <div class="flex gap-4 flex-wrap">
            <button class="px-8 py-3 rounded-2xl font-semibold
                           bg-gradient-to-r from-[#077A7D] to-[#7AE2CF] text-white 
                           shadow-lg hover:scale-105 hover:shadow-xl
                           transition duration-300">
              Get Started
            </button>

            <a href="#info">
              <button class="px-8 py-3 rounded-2xl font-semibold
                             border border-[#06202B]/20 backdrop-blur-md
                             hover:bg-white/40 transition">
                Learn More
              </button>
            </a>
          </div>
        </div>

        <!-- IMAGE CARD -->
        <div class="hidden md:block">
          <div class="relative group">
            <div class="absolute inset-0 bg-gradient-to-br from-[#7AE2CF] to-[#077A7D] rounded-3xl blur-xl opacity-60 group-hover:opacity-80 transition"></div>
            <div class="relative rounded-3xl overflow-hidden shadow-2xl border border-white/20 backdrop-blur-lg">
              <img src="static/colab-image.png" alt="" class="w-full h-[320px] object-cover group-hover:scale-105 transition duration-500">
            </div>
          </div>
        </div>

      </div>
    </main>

    <!-- WHAT WE DO -->
    <section class="py-20">
      <div class="max-w-4xl mx-auto px-6 text-center space-y-10">

        <h1 class="text-4xl font-bold text-white px-10 py-4 rounded-full 
                   bg-gradient-to-r from-black to-[#06202B] 
                   shadow-xl inline-block tracking-wide">
          What We Do
        </h1>

        <div class="bg-white/30 backdrop-blur-xl text-white rounded-3xl shadow-2xl p-10 
                    border border-white/20 bg-gradient-to-br from-[#077A7D] to-[#0aa5a8]">
          <p class="font-bold text-lg">
            Backstage is Music Colloboration App Thats primary goal is to help Upcoming or established Musicians Match with other musicians that share similar interests and visions <br>
          </p>
        </div>

      </div>
    </section>

    <!-- FEATURES -->
    <section class="pb-24">
      <div class="max-w-6xl mx-auto px-6 space-y-14">

        <!-- TITLES -->
        <div class="grid md:grid-cols-2 gap-8 text-center">
          <h1 class="text-3xl font-bold text-white px-8 py-4 rounded-full 
                     bg-gradient-to-r from-black to-[#06202B] shadow-xl">
            Matching Page
          </h1>

          <h1 class="text-3xl font-bold text-white px-8 py-4 rounded-full 
                     bg-gradient-to-r from-black to-[#06202B] shadow-xl">
            swiping
          </h1>
        </div>

        <!-- CARDS -->
        <div class="grid md:grid-cols-2 gap-10">

          <div class="group relative">
            <div class="absolute inset-0 bg-[#077A7D] rounded-3xl blur-xl opacity-40 group-hover:opacity-60 transition"></div>
            <div class="relative p-10 rounded-3xl bg-gradient-to-br from-[#077A7D] to-[#0aa5a8] 
                        text-white shadow-2xl border border-white/20 backdrop-blur-lg
                        hover:scale-[1.02] transition duration-300">
              <p class="text-center font-bold text-lg">
                The Matching is the main area all of our users will be. This area is where people will be able to request collaboration from other people by swiping left and right to either accept another person and their preferences or to decline a match with that person and
                people are presented to you based on the interests you have selected.
              </p>
            </div>
          </div>

          <div class="group relative">
            <div class="absolute inset-0 bg-[#077A7D] rounded-3xl blur-xl opacity-40 group-hover:opacity-60 transition"></div>
            <div class="relative p-13 rounded-3xl bg-gradient-to-br from-[#077A7D] to-[#0aa5a8] 
                        text-white shadow-2xl border border-white/20 backdrop-blur-lg
                        hover:scale-[1.02] transition duration-300">
              <p class="text-center font-bold text-lg">
                similar to other apps like tinder while used similarly our application is not a dating app we use the popular swiping function to suggest matches between people and allows you to accept or decline a person based on their description
              </p>
            </div>
          </div>

        </div>

      </div>
    </section>

    {% include "components/footer.html.jinja" %}

  </div>

</body>
</html>

