<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ Profile.Profile_name }} - Profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Slow, smooth rotation for the vinyl record effect */
        @keyframes slow-spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        .spinning {
            animation: slow-spin 4s linear infinite;
        }
    </style>
</head>
<body class="bg-[#F5EEDD] min-h-screen">

    {% include 'components/navbar.html.jinja' %}

    <main class="max-w-4xl mx-auto px-6 py-12">
        
        {% with messages = get_flashed_messages() %}
            {% if messages %}
                <div class="flash-messages">
                    {% for message in messages %}
                        <div style="background-color: #7AE2CF; color: #06202B; padding: 15px; border-radius: 10px; margin-bottom: 20px; font-weight: bold;">
                            ✨ {{ message }}
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        {% endwith %}
        
        <div class="bg-white rounded-[3rem] p-8 shadow-xl flex flex-col md:flex-row items-center gap-8 border border-white/50 mb-12">
            <div class="relative w-48 h-48">
                <img src="{{ url_for('static', filename='uploads/' + Profile.Profile_picture) if Profile.Profile_picture != 'default' else '/static/default_user.jpg' }}" 
                     class="w-full h-full object-cover rounded-[2.5rem] shadow-lg border-4 border-[#7AE2CF]">
            </div>

            <div class="flex-1 text-center md:text-left">
                <h1 class="text-4xl font-bold text-[#06202B] mb-2">{{ Profile.Profile_name }}</h1>
                <p class="text-gray-600 leading-relaxed mb-6">{{ Profile.description }}</p>
                <a href="{{ url_for('profile_settings') }}" 
                   class="inline-block px-6 py-2 bg-[#077A7D] text-white font-bold rounded-xl hover:bg-[#06202B] transition shadow-md">
                    Edit Profile & Tracks
                </a>
            </div>
        </div>

        <section>
            <h2 class="text-2xl font-bold text-[#06202B] mb-6 flex items-center gap-3">
                Discography 
                <span class="text-sm font-normal bg-[#7AE2CF] text-[#06202B] px-3 py-1 rounded-full">
                    {{ Songs|length }} Tracks
                </span>
            </h2>

            <div class="grid grid-cols-1 gap-6">
                {% if Songs %}
                    {% for song in Songs %}
                    <div class="relative bg-white/80 backdrop-blur-md p-5 rounded-[2.5rem] flex items-center gap-6 border border-white shadow-sm hover:shadow-md transition">
                        
                        <form action="{{ url_for('delete_song', song_id=song.Song_ID) }}" method="POST" class="absolute top-4 right-6 z-10">
                            <button type="submit" 
                                    onclick="return confirm('Remove this track?')"
                                    class="text-gray-400 hover:text-red-500 font-black text-xl transition-colors p-1 cursor-pointer"
                                    title="Delete Track">
                                ×
                            </button>
                        </form>

                        <div class="relative w-24 h-24 shrink-0">
                            <div id="cd-{{ loop.index }}" 
                                 class="w-full h-full rounded-full bg-gradient-to-tr from-[#06202B] to-gray-800 border-4 border-[#06202B] flex items-center justify-center relative shadow-lg">
                                
                                <div class="w-10 h-10 rounded-full bg-[#7AE2CF] border-2 border-[#06202B] overflow-hidden">
                                    <img src="{{ url_for('static', filename='uploads/' + Profile.Profile_picture) if Profile.Profile_picture != 'default' else '/static/default_user.jpg' }}" 
                                         class="w-full h-full object-cover">
                                </div>
                                
                                <div class="absolute w-2 h-2 rounded-full bg-white shadow-inner"></div>
                            </div>
                        </div>

                        <div class="flex-1">
                            <h3 class="text-lg font-bold text-[#06202B] mb-2">{{ song.Song_name }}</h3>
                            <audio onplay="toggleSpin('cd-{{ loop.index }}', true)" 
                                   onpause="toggleSpin('cd-{{ loop.index }}', false)" 
                                   onended="toggleSpin('cd-{{ loop.index }}', false)"
                                   controls 
                                   class="w-full h-10">
                                <source src="{{ url_for('static', filename='uploads/' + song.Song_file) }}" type="audio/mpeg">
                                Your browser does not support the audio element.
                            </audio>
                        </div>
                    </div>
                    {% endfor %}
                {% else %}
                    <div class="text-center p-12 border-2 border-dashed border-gray-300 rounded-[2.5rem]">
                        <p class="text-gray-500 font-medium">No tracks found. Get some music on here!</p>
                    </div>
                {% endif %}
            </div>
        </section>

    </main>

    <script>
        function toggleSpin(id, isPlaying) {
            const cd = document.getElementById(id);
            if (cd) {
                if (isPlaying) {
                    cd.classList.add('spinning');
                } else {
                    cd.classList.remove('spinning');
                }
            }
        }
    </script>
</body>
</html>