<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/hammer.js/2.0.8/hammer.min.js"></script>
  <title>Backstage - Matching</title>
  <style>
    .swipe-container {
      touch-action: none;
      user-select: none;
      -webkit-user-drag: none;
      z-index: 10;
    }
    .moving {
      transition: transform 0.4s ease-out, opacity 0.3s ease-out !important;
    }
    .side-label {
      position: fixed;
      top: 50%;
      transform: translateY(-50%);
      font-size: 3.5rem;
      font-weight: 900;
      letter-spacing: 0.1em;
      pointer-events: none;
      transition: opacity 0.1s ease-out;
      z-index: 0;
    }
    .left-guide { left: 8%; color: #06202B; opacity: 0.3; }
    .right-guide { right: 8%; color: #077A7D; opacity: 0.3; }
    
    .custom-scroll::-webkit-scrollbar { width: 4px; }
    .custom-scroll::-webkit-scrollbar-thumb { background: #7AE2CF; border-radius: 10px; }
  </style>
</head>

<body class="bg-[#F5EEDD] text-[#06202B] font-sans antialiased min-h-screen flex flex-col overflow-hidden">

    {% include "components/navbar.html.jinja" %}

    <div id="skip-guide" class="side-label left-guide">SKIP</div>
    <div id="invite-guide" class="side-label right-guide">INVITE</div>

    <main class="flex-1 flex flex-col items-center justify-center py-6 relative">

      {% if profile %}
        <div id="tinder-card" class="swipe-container w-[420px] rounded-3xl overflow-hidden shadow-2xl bg-white transition-transform duration-75 ease-out cursor-grab active:cursor-grabbing relative">

          <div class="w-full h-[320px] overflow-hidden">
            <img 
              src="{{ url_for('static', filename='uploads/' + profile.Profile_picture) if profile.Profile_picture != 'default' else '/static/profile.jpg' }}"
              class="w-full h-full object-cover pointer-events-none"
            >
          </div>
          
          <div class="p-4">
            <div class="flex justify-between items-start mb-2">
                <h2 class="text-2xl font-bold">{{ profile.name }}</h2>
                <span class="text-xs font-semibold bg-gray-100 px-2 py-1 rounded uppercase tracking-wider text-gray-500">Artist</span>
            </div>
            
            <hr class="mb-4 border-gray-100">

            <p class="italic text-gray-700 mb-4">"{{ profile.description }}"</p>

            {% if songs %} 
            <h3 class="text-m font-bold text-gray-400 uppercase mb-1">Discography</h3>
            <div class="border rounded overflow-y-auto custom-scroll h-20">
            {% for song in songs %}
                <div class="mb-6 p-2 border-b last:border-0">
                    <p class="text-center text-gray-700 leading-relaxed text-sm mb-1">{{ song.Song_name }}</p>
                    <audio controls class="profile-audio w-full h-10 p-1" {% if loop.first %} autoplay {% endif %}> 
                      <source src="{{ url_for('static', filename='uploads/' + song.Song_file) }}" type="audio/mpeg">
                    </audio>
                </div>
            {% endfor %}
            </div>
            {% endif %}
          </div> 

          <div class="hidden">
            <form id="invite-form" action="/invites/{{ profile.User_ID }}/send?index={{ next_index }}" method="POST"></form>
            <a id="next-link" href="{{ url_for('matching', index=next_index) }}"></a>
          </div>
        </div>
        
        <div class="bg-white px-4 py-2 rounded-3xl flex justify-evenly hover:shadow-inner mt-4 w-[420px]">
            <div>
                <a href="{{ url_for('collaborations') }}" class="bg-[#077A7D] text-white text-xs flex items-center justify-center rounded-xl font-semibold gap-2 shadow-md px-4 py-2 hover:bg-[#06202B] transition duration-200">
                    <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" viewBox="0 0 24 24"><path fill="currentColor" d="M16 17v2H2v-2s0-4 7-4s7 4 7 4m-3.5-9.5A3.5 3.5 0 1 0 9 11a3.5 3.5 0 0 0 3.5-3.5m3.44 5.5A5.32 5.32 0 0 1 18 17v2h4v-2s0-3.63-6.06-4M15 4a3.4 3.4 0 0 0-1.93.59a5 5 0 0 1 0 5.82A3.4 3.4 0 0 0 15 11a3.5 3.5 0 0 0 0-7"/></svg>
                </a>
                <p class="text-center text-[#077A7D] text-xs mt-1">Collabs</p>
            </div>
              
            <div>
                <a href="/invites" class="bg-[#077A7D] text-white text-xs flex items-center justify-center rounded-xl font-semibold gap-2 shadow-md px-4 py-2 hover:bg-[#06202B] transition duration-200">
                    <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" viewBox="0 0 24 24"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="M3 21v-1c0 -2.21 1.79 -4 4 -4h4c2.21 0 4 1.79 4 4v1"/><path d="M9 13c-1.66 0 -3 -1.34 -3 -3s1.34 -3 3 -3 3 1.34 3 3-1.34 3-3 3Z"/><path d="M15 6h6M18 3v6"/></g></svg>
                </a>
                <p class="text-center text-[#077A7D] text-xs mt-1">Invites</p>
            </div>

            <div>
                <a href="/profile" class="bg-[#077A7D] text-white text-xs flex items-center justify-center rounded-xl font-semibold gap-2 shadow-md px-4 py-2 hover:bg-[#06202B] transition duration-200">
                    <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" viewBox="0 0 24 24"><g fill="none" stroke="currentColor" stroke-dasharray="28" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="M4 21v-1c0 -3.31 2.69 -6 6 -6h4c3.31 0 6 2.69 6 6v1"><animate fill="freeze" attributeName="stroke-dashoffset" dur="0.4s" values="28;0"/></path><path stroke-dashoffset="28" d="M12 11c-2.21 0 -4 -1.79 -4 -4c0 -2.21 1.79 -4 4 -4c2.21 0 4 1.79 4 4c0 2.21 -1.79 4 -4 4Z"><animate fill="freeze" attributeName="stroke-dashoffset" begin="0.4s" dur="0.4s" to="0"/></path></g></svg>
                </a>
                <p class="text-center text-[#077A7D] text-xs mt-1">Profile</p>
            </div>
        </div>

      {% else %}
        <div class="text-center p-12 bg-white rounded-3xl shadow-xl">
            <h2 class="text-2xl font-bold">That's everyone!</h2>
            <a href="{{ url_for('matching', index=0) }}" class="mt-4 block text-[#077A7D]">Start Over</a>
        </div>
      {% endif %}

    </main>

    <script>
        const card = document.getElementById('tinder-card');
        const skipGuide = document.getElementById('skip-guide');
        const inviteGuide = document.getElementById('invite-guide');
        const allAudios = document.querySelectorAll('.profile-audio');

        if (card) {
            const hammer = new Hammer(card);

            hammer.on('pan', (ev) => {
                card.classList.remove('moving');
                card.style.transform = `translateX(${ev.deltaX}px)`;

                if (ev.deltaX > 0) { // Right (Invite)
                    inviteGuide.style.opacity = Math.max(0.3 - (ev.deltaX / 400), 0);
                    skipGuide.style.opacity = 0.3;
                } else { // Left (Skip)
                    skipGuide.style.opacity = Math.max(0.3 - (Math.abs(ev.deltaX) / 400), 0);
                    inviteGuide.style.opacity = 0.3;
                }
            });

            hammer.on('panend', (ev) => {
                card.classList.add('moving');
                if (ev.deltaX > 150) { // Right = Invite
                    card.style.transform = 'translateX(1000px)';
                    allAudios.forEach(a => a.pause());
                    // Triggers the hidden form
                    setTimeout(() => document.getElementById('invite-form').submit(), 200);
                } else if (ev.deltaX < -150) { // Left = Skip
                    card.style.transform = 'translateX(-1000px)';
                    allAudios.forEach(a => a.pause());
                    // Navigates to the hidden link
                    setTimeout(() => window.location.href = document.getElementById('next-link').href, 200);
                } else {
                    card.style.transform = 'translateX(0px)';
                    skipGuide.style.opacity = 0.3;
                    inviteGuide.style.opacity = 0.3;
                }
            });
        }

        allAudios.forEach(audio => {
            audio.addEventListener('play', () => {
                allAudios.forEach(other => { if (other !== audio) other.pause(); });
            });
        });
        // Auto-hide notifications so the user can keep swiping
document.addEventListener('DOMContentLoaded', () => {
    const toast = document.getElementById('flash-toast');
    if (toast) {
        setTimeout(() => {
            toast.style.transition = "all 0.5s ease";
            toast.style.opacity = "0";
            toast.style.transform = "translate(-50%, -20px)";
            setTimeout(() => toast.remove(), 500);
        }, 2500); // Shows for 2.5 seconds then vanishes
    }
});
    </script>


    {% with messages = get_flashed_messages(with_categories=true) %}
  {% if messages %}
    <div id="flash-toast" class="fixed top-24 left-1/2 -translate-x-1/2 z-[100] flex flex-col gap-2 pointer-events-none">
      {% for category, message in messages %}
        <div class="bg-[#077A7D] text-white px-6 py-3 rounded-full shadow-lg font-bold flex items-center gap-2 animate-in fade-in slide-in-from-top-4 duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          {{ message }}
        </div>
      {% endfor %}
    </div>
  {% endif %}
{% endwith %}
</body>
</html>