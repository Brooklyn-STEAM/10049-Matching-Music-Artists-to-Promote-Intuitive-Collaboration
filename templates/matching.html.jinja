<body class="bg-[#F5EEDD] text-[#06202B] font-sans antialiased">

    {% include "components/navbar.html.jinja"%}

    <main class="flex-1 flex items-start justify-center pt-28">

  {% if profile %}
    <div class="w-[420px] rounded-3xl overflow-hidden shadow-2xl bg-white">

      <div class="w-full h-[320px] overflow-hidden">
        <img 
          src="{{ url_for('static', filename='uploads/' + profile.Profile_picture) if profile.Profile_picture != 'default' else '/static/profile.jpg' }}"
          alt="Profile picture"
          class="w-full h-full object-cover"
        >
      </div>
      
      <div class="p-6">
        <h2 class="text-2xl font-bold mb-4">{{ profile.name }}</h2>
        
        <hr class="mb-4">

        <p class="italic text-gray-700 mb-4">
          "{{ profile.description }}"
        </p>

        <p class="text-gray-700 mb-6">
          {{ profile.discography }}
        </p>

        <div class="grid grid-cols-2 gap-4 items-center">
            <a href="{{ url_for('matching', index=next_index) }}" 
               class="bg-[#06202B] col-1 text-white text-center px-10 py-3 rounded-full font-bold hover:opacity-90 transition-all">
              « Next
            </a>
            <form class="col-2" action="/invites/{{profile.User_ID}}/send" method="post">
              <button 
                  type="submit"
                  class="bg-[#077A7D] col-2 text-white text-center px-15 py-3 rounded-full font-bold hover:opacity-90 transition-all">
                Invite 
              </button>
            </form>
        </div>
      </div>
    </div>

  {% else %}
    <div class="text-center p-10 bg-white rounded-3xl shadow-xl">
        <h2 class="text-2xl font-bold">No more matches!</h2>
        <p class="text-gray-500 mt-2">Try adding more interests to see new people like Gon.</p>
        <a href="/profile_customization" class="mt-4 inline-block text-blue-600 font-bold">Edit My Interests</a>
    </div>
  {% endif %}

</main>

    <div class="pb-20"></div>

</body>
</html>



    