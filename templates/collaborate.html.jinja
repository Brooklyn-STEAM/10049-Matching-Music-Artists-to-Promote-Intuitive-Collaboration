<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
  <title>Backstage - Collaborations</title>
</head>
<body class="bg-[#F5EEDD] text-[#06202B] font-sans antialiased min-h-screen flex flex-col">

    {% include "components/navbar.html.jinja" %}

    <main class="flex-1 container mx-auto px-4 py-12">
        <h1 class="text-center font-bold text-4xl mb-10">Your Collaborators</h1>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
            
            {% if Collabrations %}
                {% for artist in Collabrations %}
                <div class="bg-white rounded-3xl overflow-hidden shadow-lg border border-gray-100 flex flex-col">
                    
                    <div class="h-24 bg-gradient-to-br from-[#7AE2CF] to-[#077A7D]"></div>

                    <div class="px-6 pb-6 flex flex-col items-center -mt-12">
                        <div class="w-24 h-24 rounded-full border-4 border-white overflow-hidden shadow-md mb-4 bg-gray-200">
                            <img 
                                src="{{ url_for('static', filename='uploads/' + artist.Profile_picture) if artist.Profile_picture != 'default' else '/static/profile.jpg' }}" 
                                class="w-full h-full object-cover"
                                alt="Profile"
                            >
                        </div>
                        
                        <h2 class="font-bold text-xl">{{ artist.Profile_name }}</h2>
                        <p class="text-[#077A7D] font-medium text-sm mb-4">{{ artist.email }}</p>
                        
                        <div class="w-full pt-4 border-t border-gray-50 flex justify-center">
                            <a href="mailto:{{ artist.email }}" 
                               class="bg-[#06202B] text-white px-6 py-2 rounded-full font-bold text-sm hover:opacity-90 transition-all">
                                Send Message
                            </a>
                        </div>
                    </div>
                </div>
                {% endfor %}
            {% else %}
                <div class="col-span-full text-center py-20 bg-white/50 rounded-3xl border-2 border-dashed border-gray-300">
                    <p class="text-gray-500 font-medium">No collaborations yet.</p>
                    <p class="text-sm text-gray-400">Keep matching to find your team!</p>
                </div>
            {% endif %}

        </div>
    </main>

    {% include "components/footer.html.jinja" %}

</body>
</html>