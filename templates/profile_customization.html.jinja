<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <title>BackStage | Dashboard</title>
</head>
<script>

</script>
<body class="bg-[#F5EEDD] text-[#06202B] font-sans antialiased">

  {% include "navbar.html.jinja" %}

  <main class="max-w-7xl mx-auto px-12 py-10">

   
    <section class="bg-white border-2 border-[#7AE2CF] rounded-2xl p-10">

  
  

  
  <form class="space-y-8" method = "post">

    <div class="mb-8 flex items-center gap-6">
      
      <div class="bg-[#F5EEDD] border-2 border-[#7AE2CF] rounded-full p-4 h-30 w-30 flex items-center justify-center">
        <span class="text-sm text-[#06202B]/50">Picture</span>
      </div>

      
      <h2 class="text-2xl font-semibold text-[#077A7D]">
        Hello, {{ current_user.name }}
      </h2>
    </div>
    
    <div class="grid grid-cols-3 gap-8">

      
      <div class="col-span-1 flex flex-col gap-6">

        
        <div class="bg-[#F5EEDD] border-2 border-[#7AE2CF] rounded-xl p-4 h-32">
          <textarea
          name = "description"
            placeholder="Write your description..."
            class="w-full h-full bg-transparent resize-none outline-none text-[#06202B] text-lg placeholder-[#06202B]/50"
          ></textarea>
        </div>


      </div>
       <form action="/submit-interests" method="POST">
  <div class="bg-[#F5EEDD] border-2 border-[#7AE2CF] rounded-xl p-4 h-40 overflow-y-auto">
    <label class="block text-sm font-semibold text-[#077A7D] mb-2"> Interests </label>
    <div class="flex flex-col gap-3">
      <div class="px-2 flex items-center gap-2">
        <input type="checkbox" name="interests" id="rap" class="border border-[#7AE2CF] rounded-md text-[#077A7D]" value="Rap" />
        <label for="rap" class="text-sm text-[#077A7D]">Rap</label>
      </div>
      <div class="px-2 flex items-center gap-2">
        <input type="checkbox" name="interests" id="rock" class="border border-[#7AE2CF] rounded-md text-[#077A7D]" value="rock" />
        <label for="rock" class="text-sm text-[#077A7D]">rock</label>
      </div>
      <div class="px-2 flex items-center gap-2">
        <input type="checkbox" name="interests" id="rnb" class="border border-[#7AE2CF] rounded-md text-[#077A7D]" value="Rnb" />
        <label for="rnb" class="text-sm text-[#077A7D]">Rnb</label>
        </div>
      <div class="px-2 flex items-center gap-2">
        <input type="checkbox" name="interests" id="pop" class="border border-[#7AE2CF] rounded-md text-[#077A7D]" value="POP" />
        <label for="pop" class="text-sm text-[#077A7D]">POP</label>
      </div>
    </div>
  </div>
  
</form>
<button type="submit" class="mt-3 px-4 py-2 bg-[#077A7D] text-white rounded-md text-sm font-semibold">
    Submit
  </button>

      
      <div class="col-span-2">
        <div class="bg-[#F5EEDD] border-2 border-[#7AE2CF] rounded-xl p-4 h-[420px]">
          <textarea
          name = "discography"
            placeholder="Add your discography..."
            class="w-full h-full bg-transparent resize-none outline-none text-[#06202B] text-lg placeholder-[#06202B]/50"
          ></textarea>
        </div>
      </div>

    </div>
   
    <div class="flex justify-end">
      <button
        type="submit"
        class="bg-[#077A7D] text-white px-6 py-3 rounded-lg font-semibold hover:bg-[#06202B] transition"
      >
        Save Changes
      </button>
    </div>

  </form>
  

</section>


    
   

  </main>

</body>
</html>
