<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Tailwind -->
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

  <title>BackStage | Dashboard</title>
</head>

<body class="bg-[#F5EEDD] text-[#06202B] font-sans antialiased">

  {% include "components/navbar.html.jinja"%}

  <main class="max-w-7xl mx-auto px-12 py-10">

    <section class="bg-white border-2 border-[#7AE2CF] rounded-2xl p-10">

      <!-- PROFILE FORM -->
      <form action="/profile_customization" method="post" class="space-y-8" enctype="multipart/form-data">

        <!-- Profile Header -->
        <div class="mb-8 flex items-center gap-6">

          <input
            class="bg-[#F5EEDD] border-2 border-[#7AE2CF] rounded-full p-4 h-30 w-30"
            placeholder="Picture"
            type="file"
            name="Profile_picture"
            
          />

          <input
            class="text-2xl font-semibold text-[#077A7D] px-4"
            placeholder="Hello! *insert username*"
            type="text"
            name="Profile_name"
          />

        </div>

        <!-- Main Grid -->
        <div class="grid grid-cols-2 gap-8">

          <!-- LEFT COLUMN -->
          <div class="flex flex-col gap-6">

            <!-- Description -->
            <div class="bg-[#F5EEDD] border-2 border-[#7AE2CF] rounded-xl p-4 h-32">
              <textarea
                name="description"
                placeholder="Write your description..."
                class="w-full h-200 bg-transparent resize-none outline-none text-[#06202B] text-lg placeholder-[#06202B]/50"
              ></textarea>
            </div>

          </div>

          <!-- RIGHT COLUMN -->
          <div class="col-span-1">

            <!-- Discography -->
            <div class="bg-[#F5EEDD] border-2 border-[#7AE2CF] rounded-xl p-4 h-[420px]">
              <textarea
                name="discography"
                placeholder="Add your discography..."
                class="w-full h-full bg-transparent resize-none outline-none text-[#06202B] text-lg placeholder-[#06202B]/50"
              ></textarea>
            </div>

          </div>

        </div>

        <!-- Save Button -->
        <div class="flex justify-end">
          <button
            type="submit"
            class="bg-[#077A7D] text-white px-6 py-3 rounded-lg font-semibold hover:bg-[#06202B] transition"
          >
            Save Changes
          </button>
        </div>

      </form>

      <!-- INTERESTS FORM -->
      <form action="/interest" method="post" class="mt-10">

        <div class="bg-[#F5EEDD] border-2 border-[#7AE2CF] rounded-xl p-4 h-40 overflow-y-auto">

          <label class="block text-sm font-semibold text-[#077A7D] mb-2">
            Interests
          </label>

          <div class="flex flex-col gap-3">
        {%for x in Interest%}
            <div class="px-2 flex items-center gap-2">
              <input type="checkbox" name="interest" id="rap" value="{{x['interest_ID']}}"
                class="border border-[#7AE2CF] rounded-md text-[#077A7D]" />
              <label for="rap" class="text-sm text-[#077A7D]">{{x['name']}}</label>
            </div>
        {%endfor%}  
          </div>

        </div>

        <button
          type="submit"
          class="mt-4 bg-[#077A7D] text-white px-4 py-2 rounded-md text-sm font-semibold"
        >
          Submit
        </button>

      </form>

    </section>

  </main>

</body>
</html>