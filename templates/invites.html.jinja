<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
  <title>Backstage - Invites</title>
</head>
<body class="bg-[#F5EEDD] text-[#06202B] font-sans antialiased min-h-screen flex flex-col">

    {% include "components/navbar.html.jinja" %}

    <main class="flex-1 container mx-auto px-4 py-12">
        <h1 class="text-center font-bold text-4xl mb-10">Collaboration Invites</h1>

        <div class="max-w-2xl mx-auto space-y-4">
            {% if Invites_sent_to_user %}
                {% for invite in Invites_sent_to_user %}
                <div class="bg-white rounded-2xl p-4 shadow-md flex items-center justify-between border border-gray-100 transition-all hover:shadow-lg">
                    
                    <div class="flex items-center gap-4">
                        <div class="w-16 h-16 rounded-full overflow-hidden border-2 border-[#077A7D]">
                            <img 
                                src="{{ url_for('static', filename='uploads/' + invite.Profile_picture) if invite.Profile_picture != 'default' else '/static/profile.jpg' }}" 
                                class="w-full h-full object-cover"
                                alt="Profile"
                            >
                        </div>
                        <div>
                            <h2 class="font-bold text-lg leading-tight">{{ invite.Profile_name }}</h2>
                            <p class="text-sm text-gray-500">{{ invite.email }}</p>
                        </div>
                    </div>

                    <div class="flex gap-2">
                        <form action="/invites/{{ invite.User_ID }}/decline" method="POST">
                            <button type="submit" class="px-4 py-2 rounded-full border-2 border-gray-200 text-gray-500 font-bold text-sm hover:bg-gray-50 transition-all">
                                Decline
                            </button>
                        </form>

                        <form action="/invites/{{ invite.User_ID }}/accept" method="POST">
                            <button type="submit" class="px-6 py-2 rounded-full bg-[#077A7D] text-white font-bold text-sm hover:bg-[#055a5c] transition-all shadow-sm">
                                Accept
                            </button>
                        </form>
                    </div>
                </div>
                {% endfor %}
            {% else %}
                <div class="text-center py-20 bg-white/50 rounded-3xl border-2 border-dashed border-gray-300">
                    <p class="text-gray-500 font-medium">No pending invites at the moment.</p>
                    <a href="/matching" class="text-[#077A7D] font-bold mt-2 inline-block hover:underline">Go find collaborators →</a>
                </div>
            {% endif %}
        </div>
    </main>

    {% include "components/footer.html.jinja" %}

</body>
</html>