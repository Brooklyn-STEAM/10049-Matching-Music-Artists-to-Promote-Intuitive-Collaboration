<header class="bg-gradient-to-r from-[#F5EEDD] to-[#7AE2CF] shadow-sm">
      <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
       <a href="/">
        <div class="flex items-center gap-2">
          <img src="/static/Backstage_No_Bg.png" alt="logo" class="h-20">
          <h1 class="text-2xl font-semibold tracking-tight">BackStage</h1>
        </div>
        </a>
      {% if not current_user.is_authenticated%}
        <div class="flex items-center gap-4">
          <a href="/login"class="px-5 py-2 rounded-xl font-medium 
                         text-[#06202B] 
                         hover:bg-[#06202B]/10 
                         transition">
            Login
          </a>
      
          <a href="/register" class="px-6 py-2 rounded-xl font-semibold 
                         bg-[#077A7D] text-white 
                         shadow-md
                         hover:bg-[#06202B] 
                         hover:shadow-lg
                         transition duration-200">
            Sign Up
          </a>
          </div>
      {%else%}
      <div class="flex items-center gap-4">
          <a href="/profile" class="bg-[#077A7D] 
                          text-white rounded-xl font-semibold 
                          shadow-md
                          px-4 py-2
                          hover:bg-[#06202B] 
                          hover:shadow-lg
                          transition duration-200"
                                    >Profile</a>
          <a href="/matching" class="bg-[#077A7D] 
                          text-white rounded-xl font-semibold 
                          shadow-md
                          px-4 py-2
                          hover:bg-[#06202B] 
                          hover:shadow-lg
                          transition duration-200"
                                    >Matching</a>
          <a href="{{ url_for('collaborate', User_ID=current_user.id) }}" class="bg-[#077A7D] 
                          text-white rounded-xl font-semibold 
                          flex justify-center
                          gap-2
                          shadow-md
                          px-4 py-2
                          hover:bg-[#06202B] 
                          hover:shadow-lg
                          transition duration-200"
                                    >Collabs
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M16 17v2H2v-2s0-4 7-4s7 4 7 4m-3.5-9.5A3.5 3.5 0 1 0 9 11a3.5 3.5 0 0 0 3.5-3.5m3.44 5.5A5.32 5.32 0 0 1 18 17v2h4v-2s0-3.63-6.06-4M15 4a3.4 3.4 0 0 0-1.93.59a5 5 0 0 1 0 5.82A3.4 3.4 0 0 0 15 11a3.5 3.5 0 0 0 0-7"/></svg></a>
                                    <div class="flex items-center gap-4">
          <a href="/invites" class="bg-[#077A7D] 
                          text-white rounded-xl font-semibold 
                          flex justify-center
                          gap-2
                          shadow-md
                          px-4 py-2
                          hover:bg-[#06202B] 
                          hover:shadow-lg
                          transition duration-200"
                                    >Invites
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><g stroke-dasharray="22"><path d="M3 21v-1c0 -2.21 1.79 -4 4 -4h4c2.21 0 4 1.79 4 4v1"><animate fill="freeze" attributeName="stroke-dashoffset" dur="0.3s" values="22;0"/></path><path stroke-dashoffset="22" d="M9 13c-1.66 0 -3 -1.34 -3 -3c0 -1.66 1.34 -3 3 -3c1.66 0 3 1.34 3 3c0 1.66 -1.34 3 -3 3Z"><animate fill="freeze" attributeName="stroke-dashoffset" begin="0.3s" dur="0.3s" to="0"/></path></g><g stroke-dasharray="8" stroke-dashoffset="8"><path d="M15 6h6"><animate fill="freeze" attributeName="stroke-dashoffset" begin="0.7s" dur="0.2s" to="0"/></path><path d="M18 3v6"><animate fill="freeze" attributeName="stroke-dashoffset" begin="0.9s" dur="0.2s" to="0"/></path></g></g></svg>
         <div class="flex items-center gap-4">
          <a href="/logout"class="px-5 py-2 rounded-xl font-medium 
                         text-[#06202B] 
                         hover:bg-[#06202B]/10 
                         transition">
            Logout
          </a>
        </div>
      {%endif%}
      </div>
    </header>